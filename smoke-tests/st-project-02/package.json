{
  "name": "codex-jsonl-summarizer",
  "version": "0.1.0",
  "description": "Summarize Codex JSONL rollout files into a structured JSON report",
  "type": "module",
  "bin": {
    "codex-jsonl-summarizer": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "clean": "rm -rf dist",
    "cli": "node dist/src/cli.js",
    "summarize": "node dist/src/cli.js"
  },
  "keywords": [
    "codex",
    "jsonl",
    "summary",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  }
}
